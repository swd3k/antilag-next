<Window x:Class="AntiLagNext.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AntiLagNext.App.ViewModels"
        xmlns:views="clr-namespace:AntiLagNext.App.Views"
        Title="AntiLag Next"
        Height="720" Width="1100"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        StateChanged="OnStateChanged"
        Closing="OnClosing">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
      <views:DashboardView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:ProfilesViewModel}">
      <views:ProfilesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MonitoringViewModel}">
      <views:MonitoringView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:BackupsViewModel}">
      <views:BackupsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:TipsViewModel}">
      <views:TipsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource NavBackground}" Padding="8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="8,12,8,16">
          <Image Source="pack://application:,,,/Assets/logo.png"
                 Width="72" Height="72" Stretch="Uniform"
                 HorizontalAlignment="Center" Margin="0,0,0,8" />
          <TextBlock Text="AntiLag Next" FontSize="20" FontWeight="Bold"
                     Foreground="White" HorizontalAlignment="Center" />
          <TextBlock Text="latency · fps · control" FontSize="11"
                     Foreground="{StaticResource MutedText}" HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="8">
          <TextBlock Text="{Binding Dashboard.StatusLine}" TextWrapping="Wrap"
                     FontSize="11" Foreground="{StaticResource MutedText}" Margin="0,0,0,8" />
        </StackPanel>

        <StackPanel>
          <Button Content="Панель" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
          <Button Content="Профили" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Profiles"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
          <Button Content="Мониторинг" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Monitoring"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
          <Button Content="Бэкапы" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Backups"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
          <Button Content="Подсказки" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Tips"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
          <Button Content="Настройки" Style="{StaticResource MaterialDesignFlatButton}"
                  Command="{Binding NavigateCommand}" CommandParameter="Settings"
                  HorizontalContentAlignment="Left" Margin="0,2" Height="40" />
        </StackPanel>
      </DockPanel>
    </Border>

    <DockPanel Grid.Column="1" Background="{StaticResource ContentBackground}">
      <Border DockPanel.Dock="Top" Padding="20,16" Background="{StaticResource CardBackground}">
        <TextBlock Text="{Binding CurrentPageTitle}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
      </Border>

      <Border DockPanel.Dock="Top" Background="#2D1B4E" Padding="16" Margin="16,12,16,0"
              Visibility="{Binding ShowFirstRunBanner, Converter={StaticResource BoolToVis}}">
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="Запустить бенчмарк"
                  Style="{StaticResource MaterialDesignRaisedButton}"
                  Command="{Binding RunFirstBenchmarkCommand}" Margin="12,0,0,0" />
          <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                     Text="Первый запуск: короткий бенчмарк latency/таймера подберёт профиль с пояснениями на русском." />
        </DockPanel>
      </Border>

      <ContentControl Content="{Binding CurrentPage}" Margin="16" />
    </DockPanel>
  </Grid>
</Window>
