<Window x:Class="AntiLagNext.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:AntiLagNext.App.ViewModels"
        xmlns:views="clr-namespace:AntiLagNext.App.Views"
        Title="AntiLag Next"
        Height="820" Width="1320"
        MinHeight="680" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="{DynamicResource ContentBackground}"
        TextElement.Foreground="{DynamicResource PrimaryText}"
        FontFamily="Segoe UI Variable, Segoe UI"
        StateChanged="OnStateChanged"
        Closing="OnClosing">

  <Window.Resources>
    <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:ProfilesViewModel}"><views:ProfilesView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:MonitoringViewModel}"><views:MonitoringView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:PluginsViewModel}"><views:PluginsView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:BackupsViewModel}"><views:BackupsView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:TipsViewModel}"><views:TipsView /></DataTemplate>
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView /></DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="248" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- SIDEBAR (showcase) -->
    <Border Grid.Column="0" Background="{DynamicResource NavBackground}"
            BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <!-- Brand: PNG (not ICO) for crisp UI; transparent tile, no heavy cyan box -->
        <Border DockPanel.Dock="Top" Height="64" BorderBrush="{DynamicResource BorderBrushSubtle}"
                BorderThickness="0,0,0,1" Padding="16,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0" ClipToBounds="True"
                    Background="Transparent">
              <Image Source="pack://application:,,,/Assets/logo.png"
                     Stretch="Uniform" Margin="2" SnapsToDevicePixels="True"
                     RenderOptions.BitmapScalingMode="HighQuality"
                     RenderOptions.EdgeMode="Aliased" />
            </Border>
            <TextBlock VerticalAlignment="Center" FontSize="16" FontWeight="Light"
                       Foreground="{DynamicResource PrimaryText}">
              <Run Text="ANTILAG " /><Run Text="NEXT" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" />
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Settings under brand (showcase) -->
        <Border DockPanel.Dock="Top" Padding="12" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,0,0,1">
          <Button Style="{StaticResource NavItemButton}" Margin="0"
                  Command="{Binding NavigateCommand}" CommandParameter="Settings"
                  Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Settings}"
                  Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Settings}"
                  Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Settings}">
            <StackPanel Orientation="Horizontal">
              <materialDesign:PackIcon Kind="CogOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
              <TextBlock Text="{Binding NavSettings}" VerticalAlignment="Center" FontSize="13" />
            </StackPanel>
          </Button>
        </Border>

        <!-- Status chip under Settings -->
        <Border DockPanel.Dock="Top" Margin="12,8,12,0" Padding="12,10" CornerRadius="12"
                Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
              <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center"
                       Fill="{Binding Dashboard.OptimizationsActive, Converter={StaticResource StatusBrush}}" />
              <TextBlock Text="{Binding NavSystemChip}" FontSize="10" FontWeight="Bold"
                         Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="{Binding Dashboard.StatusLine}" FontSize="11"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                       Foreground="{DynamicResource PrimaryText}" FontFamily="Cascadia Mono, Consolas, JetBrains Mono"
                       ToolTip="{Binding Dashboard.StatusLine}" />
          </StackPanel>
        </Border>

        <!-- GitHub footer -->
        <Border DockPanel.Dock="Bottom" Padding="20,16" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,1,0,0">
          <Button Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Padding="0"
                  Command="{Binding OpenGitHubCommand}" MinHeight="24" Height="Auto">
            <StackPanel Orientation="Horizontal">
              <materialDesign:PackIcon Kind="Github" Width="18" Height="18" Margin="0,0,10,0"
                                       VerticalAlignment="Center" Foreground="{DynamicResource MutedText}" />
              <TextBlock Text="{Binding NavGithub}" FontSize="12" FontWeight="Medium" VerticalAlignment="Center"
                         Foreground="{DynamicResource MutedText}" />
            </StackPanel>
          </Button>
        </Border>

        <!-- Nav items -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,12,12,8"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Dashboard"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Dashboard}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Dashboard}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Dashboard}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ChartTimelineVariant" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavDashboard}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Profiles"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Profiles}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Profiles}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Profiles}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="GamepadVariantOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavProfiles}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Monitoring"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Monitoring}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Monitoring}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Monitoring}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavMonitoring}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Plugins"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Plugins}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Plugins}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Plugins}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PuzzleOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavPlugins}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Backups"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Backups}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Backups}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Backups}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="DatabaseOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavBackups}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource NavItemButton}"
                    Command="{Binding NavigateCommand}" CommandParameter="Tips"
                    Background="{Binding CurrentNavKey, Converter={StaticResource NavBg}, ConverterParameter=Tips}"
                    Foreground="{Binding CurrentNavKey, Converter={StaticResource NavFg}, ConverterParameter=Tips}"
                    Tag="{Binding CurrentNavKey, Converter={StaticResource NavRail}, ConverterParameter=Tips}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="LightbulbOnOutline" Width="20" Height="20" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding NavTips}" VerticalAlignment="Center" FontSize="13" />
              </StackPanel>
            </Button>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- MAIN -->
    <Grid Grid.Column="1" Background="{DynamicResource ContentBackground}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Margin="32,24,32,0" CornerRadius="12" Padding="16,14"
              BorderBrush="#4000BFFF" BorderThickness="1"
              Visibility="{Binding ShowFirstRunBanner, Converter={StaticResource BoolToVis}}">
        <Border.Background>
          <SolidColorBrush Color="#1A00BFFF" />
        </Border.Background>
        <DockPanel>
          <Button DockPanel.Dock="Right" Content="{Binding FirstRunCta}" Style="{StaticResource PrimaryButton}"
                  Command="{Binding RunFirstBenchmarkCommand}" Margin="16,0,0,0" VerticalAlignment="Center" />
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding FirstRunTitle}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{Binding FirstRunHint}"
                       TextWrapping="Wrap" Foreground="{DynamicResource MutedText}" Margin="0,4,0,0" FontSize="12" />
          </StackPanel>
        </DockPanel>
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    Padding="{StaticResource PagePadding}" CanContentScroll="False">
        <Grid MinWidth="720" MaxWidth="1200" HorizontalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource PageTitle}" />
            <TextBlock Text="{Binding CurrentPageSubtitle}" Style="{StaticResource PageSubtitle}"
                       Visibility="{Binding CurrentPageSubtitle, Converter={StaticResource StringToVis}}" />
          </StackPanel>

          <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Top" />
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>
