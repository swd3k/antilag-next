<UserControl x:Class="AntiLagNext.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource CardBackground}"
            BorderBrush="{StaticResource BorderBrushSubtle}" BorderThickness="1" CornerRadius="20" Margin="0,0,20,0">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="20,16" BorderBrush="{StaticResource BorderBrushSubtle}" BorderThickness="0,0,0,1">
          <DockPanel>
            <StackPanel>
              <TextBlock Text="GAME PROFILES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedText}" />
              <TextBlock Text="Пресеты и auto-switch" FontSize="10" FontFamily="Consolas"
                         Foreground="{StaticResource DimText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="VIEW ALL" Style="{StaticResource GhostButton}"
                    Command="{Binding SaveProfilesCommand}" VerticalAlignment="Center" />
          </DockPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Padding="12">
          <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddCustomProfileCommand}" HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal">
              <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,8,0" />
              <TextBlock Text="NEW PROFILE" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Border>
        <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                 Style="{StaticResource ModernListBox}" ItemContainerStyle="{StaticResource ModernListBoxItem}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <DockPanel>
                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,14,0"
                        Background="#1A06B6D4">
                  <materialDesign:PackIcon Kind="GamepadVariant" Width="20" Height="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource AccentBrush}" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                  <TextBlock Text="{Binding Kind}" FontSize="11" FontFamily="Consolas"
                             Foreground="{StaticResource MutedText}" Margin="0,2,0,0" />
                </StackPanel>
              </DockPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
          <StackPanel DataContext="{Binding SelectedProfile}">
            <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Light" />
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,8,0,0"
                       Foreground="{StaticResource MutedText}" FontSize="13" LineHeight="20" />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
          <StackPanel>
            <TextBlock Text="GAME EXES (AUTO-SWITCH)" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource MutedText}" Margin="0,0,0,12" />
            <ListBox ItemsSource="{Binding SelectedProfile.GameExecutables}" Height="120"
                     Style="{StaticResource ModernListBox}" ItemContainerStyle="{StaticResource ModernListBoxItem}" />
            <DockPanel Margin="0,12,0,0">
              <Button DockPanel.Dock="Right" Content="ADD" Style="{StaticResource PrimaryButton}"
                      Command="{Binding AddGameExeCommand}" Padding="16,10" Margin="10,0,0,0" />
              <TextBox materialDesign:HintAssist.Hint="game.exe"
                       Text="{Binding NewGameExe, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
          </StackPanel>
        </Border>

        <Button Content="APPLY PROFILE" Style="{StaticResource PrimaryButton}"
                Command="{Binding ApplySelectedCommand}" HorizontalAlignment="Left" MinWidth="180" />
        <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" FontFamily="Consolas" FontSize="11"
                   Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
