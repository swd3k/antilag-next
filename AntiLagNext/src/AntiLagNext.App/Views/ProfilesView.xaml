<UserControl x:Class="AntiLagNext.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320" MinWidth="280" MaxWidth="380" />
      <ColumnDefinition Width="20" />
      <ColumnDefinition Width="*" MinWidth="320" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1" CornerRadius="16">
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,0,0,1">
          <DockPanel>
            <StackPanel>
              <TextBlock Text="{Binding LabelListTitle}" FontSize="10" FontWeight="Bold"
                         Foreground="{DynamicResource MutedText}" />
              <TextBlock Text="{Binding LabelListSub}" FontSize="10" FontFamily="Consolas"
                         Foreground="{DynamicResource DimText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button DockPanel.Dock="Right" Content="{Binding LabelSave}" Style="{StaticResource GhostButton}"
                    Command="{Binding SaveProfilesCommand}" VerticalAlignment="Center" />
          </DockPanel>
        </Border>

        <!-- Always-visible actions: New + Delete (Delete only works for Custom) -->
        <Border DockPanel.Dock="Bottom" Padding="12,10" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,1,0,0"
                Background="{DynamicResource CardSoftBackground}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="8" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddCustomProfileCommand}" HorizontalAlignment="Stretch" Height="40">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"
                                         Foreground="{DynamicResource OnAccentText}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding LabelNew}" VerticalAlignment="Center" FontSize="10"
                           Foreground="{DynamicResource OnAccentText}" />
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Style="{StaticResource DangerOutlineButton}"
                    Command="{Binding DeleteSelectedCommand}" HorizontalAlignment="Stretch" Height="40"
                    ToolTip="{Binding DeleteTooltip}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" Margin="0,0,6,0"
                                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding LabelDelete}" VerticalAlignment="Center" FontSize="10" />
              </StackPanel>
            </Button>
          </Grid>
        </Border>

        <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                 Style="{StaticResource ModernListBox}" ItemContainerStyle="{StaticResource ModernListBoxItem}"
                 Margin="0,4,0,0">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <DockPanel LastChildFill="True">
                <!-- Per-row delete for custom profiles (always visible when custom) -->
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Padding="8,4" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        Visibility="{Binding Kind, Converter={StaticResource ProfileCustomVis}}"
                        ToolTip="Delete">
                  <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18"
                                           Foreground="{DynamicResource DangerBrush}" />
                </Button>
                <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0"
                        Background="#1A00BFFF">
                  <materialDesign:PackIcon Kind="GamepadVariant" Width="20" Height="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentBrush}" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                             Foreground="{DynamicResource PrimaryText}" />
                  <TextBlock FontSize="11" FontFamily="Consolas"
                             Foreground="{DynamicResource MutedText}" Margin="0,2,0,0">
                    <TextBlock.Text>
                      <MultiBinding StringFormat="{}{0}">
                        <Binding Path="Kind" />
                      </MultiBinding>
                    </TextBlock.Text>
                  </TextBlock>
                </StackPanel>
              </DockPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="16">
          <DockPanel>
            <Button DockPanel.Dock="Right" Style="{StaticResource DangerOutlineButton}"
                    Command="{Binding DeleteSelectedCommand}" Margin="12,0,0,0"
                    VerticalAlignment="Top" MinWidth="120"
                    Visibility="{Binding CanDeleteSelected, Converter={StaticResource BoolToVis}}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}">
              <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" Margin="0,0,8,0" />
                <TextBlock Text="{Binding LabelDelete}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <StackPanel DataContext="{Binding SelectedProfile}">
              <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Light"
                         Foreground="{DynamicResource PrimaryText}" />
              <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,8,0,0"
                         Foreground="{DynamicResource MutedText}" FontSize="13" LineHeight="20" />
            </StackPanel>
          </DockPanel>
        </Border>

        <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
          <StackPanel>
            <TextBlock Text="{Binding LabelGameExes}" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource MutedText}" Margin="0,0,0,12" />
            <ListBox ItemsSource="{Binding SelectedProfile.GameExecutables}" Height="120"
                     Style="{StaticResource ModernListBox}" ItemContainerStyle="{StaticResource ModernListBoxItem}" />
            <DockPanel Margin="0,12,0,0">
              <Button DockPanel.Dock="Right" Content="{Binding LabelAdd}" Style="{StaticResource PrimaryButton}"
                      Command="{Binding AddGameExeCommand}" Padding="16,10" Margin="10,0,0,0" />
              <TextBox materialDesign:HintAssist.Hint="game.exe"
                       Text="{Binding NewGameExe, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
          </StackPanel>
        </Border>

        <Button Content="{Binding LabelApply}" Style="{StaticResource PrimaryButton}"
                Command="{Binding ApplySelectedCommand}" HorizontalAlignment="Left" MinWidth="180"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
        <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" FontFamily="Consolas" FontSize="11"
                   Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
