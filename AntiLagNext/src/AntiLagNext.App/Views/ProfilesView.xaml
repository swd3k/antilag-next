<UserControl x:Class="AntiLagNext.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <DockPanel Grid.Column="0" Margin="0,0,12,0">
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
        <Button Content="+" Command="{Binding AddCustomProfileCommand}"
                Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Margin="0,0,8,0"
                ToolTip="Новый профиль" />
        <Button Content="Сохранить" Command="{Binding SaveProfilesCommand}"
                Style="{StaticResource MaterialDesignOutlinedButton}" />
      </StackPanel>
      <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
               DisplayMemberPath="Name" />
    </DockPanel>

    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel DataContext="{Binding SelectedProfile}">
        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" />
        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,8,0,12"
                   Foreground="{StaticResource MutedText}" />

        <TextBlock Text="Игры (авто-переключение)" FontWeight="SemiBold" Margin="0,8,0,4" />
        <ListBox ItemsSource="{Binding GameExecutables}" Height="100" Margin="0,0,0,8" />
        <DockPanel DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
          <Button DockPanel.Dock="Right" Content="Добавить" Command="{Binding AddGameExeCommand}" Margin="8,0,0,0" />
          <TextBox materialDesign:HintAssist.Hint="game.exe"
                   Text="{Binding NewGameExe, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>

        <TextBlock Text="Исключения очистки памяти" FontWeight="SemiBold" Margin="0,16,0,4"
                   DataContext="{Binding SelectedProfile, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <ListBox ItemsSource="{Binding MemoryCleanupExclusions}" Height="100" Margin="0,0,0,8"
                 DataContext="{Binding SelectedProfile, RelativeSource={RelativeSource AncestorType=UserControl}}" />

        <Button Content="Применить профиль" Margin="0,16,0,0"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Command="{Binding DataContext.ApplySelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <TextBlock Text="{Binding DataContext.StatusMessage, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Margin="0,8,0,0" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
