<UserControl x:Class="AntiLagNext.App.Views.TipsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <ItemsControl ItemsSource="{Binding Tips}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <UniformGrid Columns="2" />
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Border Style="{StaticResource GlassCard}" Margin="0,0,16,16" CornerRadius="20" MinHeight="170">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
              <Border Width="36" Height="36" CornerRadius="10" Background="#1A06B6D4" Margin="0,0,12,0">
                <materialDesign:PackIcon Kind="LightbulbOnOutline" Width="18" Height="18"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Foreground="{StaticResource AccentBrush}" />
              </Border>
              <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Text="BENEFIT" FontSize="10" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Benefit}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource PrimaryText}" LineHeight="18" />
            <TextBlock Text="TRADEOFF" FontSize="10" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,12,0,4" />
            <TextBlock Text="{Binding Tradeoff}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource MutedText}" LineHeight="18" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
