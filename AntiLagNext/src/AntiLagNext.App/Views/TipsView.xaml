<UserControl x:Class="AntiLagNext.App.Views.TipsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <ItemsControl ItemsSource="{Binding Tips}">
    <ItemsControl.ItemsPanel>
      <ItemsPanelTemplate>
        <UniformGrid Columns="2" />
      </ItemsPanelTemplate>
    </ItemsControl.ItemsPanel>
    <ItemsControl.ItemTemplate>
      <DataTemplate>
        <Border Style="{StaticResource GlassCard}" Margin="0,0,16,16" CornerRadius="16"
                Padding="18" MinHeight="200" VerticalAlignment="Stretch">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
              <Border Width="36" Height="36" CornerRadius="10" Background="#1A00BFFF" Margin="0,0,12,0">
                <materialDesign:PackIcon Kind="LightbulbOnOutline" Width="18" Height="18"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Foreground="{DynamicResource AccentBrush}" />
              </Border>
              <TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="14" FontWeight="SemiBold"
                         TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="20"
                         Foreground="{DynamicResource PrimaryText}" />
            </StackPanel>
            <TextBlock FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,4"
                       Text="{Binding DataContext.LabelBenefit, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <TextBlock Text="{Binding Benefit, Mode=OneWay}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource PrimaryText}" LineHeight="18" MinHeight="40" />
            <TextBlock FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource WarningBrush}" Margin="0,12,0,4"
                       Text="{Binding DataContext.LabelTradeoff, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            <TextBlock Text="{Binding Tradeoff, Mode=OneWay}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource MutedText}" LineHeight="18" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ItemsControl.ItemTemplate>
  </ItemsControl>
</UserControl>
