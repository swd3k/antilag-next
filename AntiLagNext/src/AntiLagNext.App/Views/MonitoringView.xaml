<UserControl x:Class="AntiLagNext.App.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <StackPanel>
    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
      <Button Content="Старт" Command="{Binding StartCommand}"
              Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0" />
      <Button Content="Стоп" Command="{Binding StopCommand}"
              Style="{StaticResource MaterialDesignOutlinedButton}" />
      <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="16,0,0,0" />
    </StackPanel>

    <UniformGrid Columns="2" Rows="2">
      <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16" Margin="4">
        <StackPanel>
          <TextBlock Text="Scheduling latency" Foreground="{StaticResource MutedText}" />
          <TextBlock FontSize="28" FontWeight="Bold">
            <Run Text="{Binding LatestLatencyUs, StringFormat=F1}" /><Run Text=" мкс" FontSize="14" />
          </TextBlock>
          <TextBlock Text="Прокси DPC/ISR (waitable timer + QPC)" FontSize="11" Foreground="{StaticResource MutedText}" />
        </StackPanel>
      </Border>
      <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16" Margin="4">
        <StackPanel>
          <TextBlock Text="Timer resolution" Foreground="{StaticResource MutedText}" />
          <TextBlock FontSize="28" FontWeight="Bold">
            <Run Text="{Binding LatestTimerMs, StringFormat=F3}" /><Run Text=" мс" FontSize="14" />
          </TextBlock>
        </StackPanel>
      </Border>
      <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16" Margin="4">
        <StackPanel>
          <TextBlock Text="CPU (app proxy)" Foreground="{StaticResource MutedText}" />
          <TextBlock FontSize="28" FontWeight="Bold">
            <Run Text="{Binding LatestCpu, StringFormat=F1}" /><Run Text=" %" FontSize="14" />
          </TextBlock>
        </StackPanel>
      </Border>
      <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16" Margin="4">
        <StackPanel>
          <TextBlock Text="RAM used" Foreground="{StaticResource MutedText}" />
          <TextBlock FontSize="28" FontWeight="Bold">
            <Run Text="{Binding LatestMemMb, StringFormat=F0}" /><Run Text=" МБ" FontSize="14" />
          </TextBlock>
          <TextBlock Text="{Binding PowerSourceText}" FontSize="11" Foreground="{StaticResource MutedText}" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <TextBlock Text="Последние сэмплы" FontWeight="SemiBold" Margin="0,16,0,8" />
    <ListView ItemsSource="{Binding Samples}" Height="280"
              materialDesign:DataGridAssist.CellPadding="4">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Время" Width="160"
                          DisplayMemberBinding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" />
          <GridViewColumn Header="Latency мкс" Width="100"
                          DisplayMemberBinding="{Binding SchedulingLatencyUs, StringFormat=F1}" />
          <GridViewColumn Header="Timer мс" Width="90"
                          DisplayMemberBinding="{Binding TimerResolutionMs, StringFormat=F3}" />
          <GridViewColumn Header="CPU %" Width="70"
                          DisplayMemberBinding="{Binding CpuUsagePercent, StringFormat=F1}" />
          <GridViewColumn Header="RAM МБ" Width="90"
                          DisplayMemberBinding="{Binding UsedMemoryMb, StringFormat=F0}" />
        </GridView>
      </ListView.View>
    </ListView>
  </StackPanel>
</UserControl>
