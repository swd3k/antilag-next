<UserControl x:Class="AntiLagNext.App.Views.MonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:AntiLagNext.App.Controls">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Content="{Binding LabelStart}" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" />
        <Button Content="{Binding LabelStop}" Command="{Binding StopCommand}" Style="{StaticResource DangerOutlineButton}" Margin="0,0,10,0" />
        <Button Content="{Binding LabelClear}" Command="{Binding ClearCommand}" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Height="40" />
        <Button Style="{StaticResource GhostButton}" Command="{Binding ToggleAlertsCommand}" Height="40"
                Content="{Binding AlertsToggleLabel}" />
      </StackPanel>
      <Border Grid.Column="1" Style="{StaticResource StatusPill}" VerticalAlignment="Center"
              Background="#1A34D399" BorderBrush="#3334D399"
              Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
        <StackPanel Orientation="Horizontal">
          <Ellipse Width="6" Height="6" Margin="0,0,8,0" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center">
            <Ellipse.Effect>
              <DropShadowEffect Color="#34D399" BlurRadius="8" ShadowDepth="0" Opacity="0.9" />
            </Ellipse.Effect>
          </Ellipse>
          <TextBlock Text="{Binding LabelRunning}" FontSize="11" FontFamily="Consolas"
                     Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
    </Grid>

    <StackPanel Grid.Row="1" Margin="0,0,0,16">
      <TextBlock Text="{Binding MetricDisclaimer}" Style="{StaticResource DisclaimerText}" />
      <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" FontFamily="Consolas" FontSize="11"
                 Foreground="{DynamicResource AccentBrush}" TextWrapping="Wrap"
                 Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}" />
    </StackPanel>

    <Border Grid.Row="2" Margin="0,0,0,16" CornerRadius="12" Padding="14"
            Background="#33F43F5E" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1"
            Visibility="{Binding HasActiveAlert, Converter={StaticResource BoolToVis}}">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="{Binding LabelDismiss}" Style="{StaticResource GhostButton}"
                Command="{Binding DismissAlertCommand}" />
        <TextBlock Text="{Binding AlertBanner}" TextWrapping="Wrap" FontWeight="SemiBold" VerticalAlignment="Center"
                   Foreground="{DynamicResource PrimaryText}" />
      </DockPanel>
    </Border>

    <Border Grid.Row="3" Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="16">
      <StackPanel>
        <DockPanel Margin="0,0,0,10">
          <TextBlock Text="{Binding LabelSession}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
          <Border DockPanel.Dock="Right" CornerRadius="8" Padding="10,4"
                  BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1">
            <TextBlock Text="{Binding LoadContextText}" FontSize="10" FontFamily="Consolas" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" />
          </Border>
        </DockPanel>
        <TextBlock Text="{Binding SessionSummary}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                   Foreground="{DynamicResource PrimaryText}" LineHeight="18" />
        <TextBlock Text="{Binding BaselineText}" TextWrapping="Wrap" FontSize="12" Margin="0,10,0,0"
                   FontFamily="Consolas" Foreground="{DynamicResource SuccessBrush}" />
        <TextBlock Text="{Binding BehaviorHint}" TextWrapping="Wrap" FontSize="11" Margin="0,10,0,0"
                   Foreground="{DynamicResource MutedText}" LineHeight="16" />
      </StackPanel>
    </Border>

    <Border Grid.Row="4" Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,16" CornerRadius="16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="{Binding LabelChartTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedText}" />
            <TextBlock Text="{Binding LabelChartSub}" FontSize="10" FontFamily="Consolas"
                       Foreground="{DynamicResource DimText}" Margin="0,4,0,0" />
          </StackPanel>
          <Border DockPanel.Dock="Right" CornerRadius="8" Padding="10,4"
                  BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1">
            <TextBlock Text="{Binding LatencyQuality}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentBrush}" />
          </Border>
        </DockPanel>
        <Border Grid.Row="1" Height="220" CornerRadius="12" ClipToBounds="True"
                BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1"
                Background="{DynamicResource CardSoftBackground}">
          <ctrl:LatencyWaveform Values="{Binding LatencySeries}"
                                EmptyText="{Binding LabelChartWaiting}"
                                MaxValue="400" GreenThreshold="50" YellowThreshold="150" UnitLabel="µs" />
        </Border>
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,14,0,0">
          <Border Style="{StaticResource MetricChip}" Margin="0,0,8,0" HorizontalAlignment="Stretch">
            <StackPanel>
              <TextBlock Text="{Binding LabelMedian}" FontSize="10" Foreground="{DynamicResource MutedText}" />
              <TextBlock Text="{Binding LatestLatencyUs, StringFormat={}{0:F0} µs}" FontSize="16"
                         FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource MetricChip}" Margin="0,0,8,0" HorizontalAlignment="Stretch">
            <StackPanel>
              <TextBlock Text="{Binding LabelMaxNow}" FontSize="10" Foreground="{DynamicResource MutedText}" />
              <TextBlock Text="{Binding LatestMaxLatencyUs, StringFormat={}{0:F0} µs}" FontSize="16"
                         FontFamily="Consolas" Foreground="{DynamicResource WarningBrush}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource MetricChip}" Margin="0,0,8,0" HorizontalAlignment="Stretch">
            <StackPanel>
              <TextBlock Text="{Binding LabelIdleBase}" FontSize="10" Foreground="{DynamicResource MutedText}" />
              <TextBlock Text="{Binding IdleBaselineUs, StringFormat={}{0:F0} µs}" FontSize="16"
                         FontFamily="Consolas" Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>
          </Border>
          <Border Style="{StaticResource MetricChip}" Margin="0" HorizontalAlignment="Stretch">
            <StackPanel>
              <TextBlock Text="{Binding LabelPeakP99}" FontSize="10" Foreground="{DynamicResource MutedText}" />
              <TextBlock FontSize="16" FontFamily="Consolas" Foreground="{DynamicResource PrimaryText}">
                <Run Text="{Binding PeakLatencyUs, StringFormat=F0, Mode=OneWay}" />
                <Run Text=" / " Foreground="{DynamicResource DimText}" />
                <Run Text="{Binding P99LatencyUs, StringFormat=F0, Mode=OneWay}" />
              </TextBlock>
            </StackPanel>
          </Border>
        </UniformGrid>
      </Grid>
    </Border>

    <Border Grid.Row="5" Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="1" CornerRadius="16"
            MaxHeight="280">
      <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="{DynamicResource BorderBrushSubtle}" BorderThickness="0,0,0,1">
          <TextBlock Text="{Binding LabelLogTitle}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource MutedText}" />
        </Border>
        <Grid>
          <ListBox ItemsSource="{Binding Spikes}" Style="{StaticResource ModernListBox}"
                   ItemContainerStyle="{StaticResource ModernListBoxItem}"
                   Visibility="{Binding Spikes.Count, Converter={StaticResource CountNonZeroToVis}}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding DisplayLine}" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryText}" FontSize="12" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock Text="{Binding LabelSpikesEmpty}" TextWrapping="Wrap" TextAlignment="Center"
                     VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24" MaxWidth="360"
                     FontSize="12" Foreground="{DynamicResource DimText}"
                     Visibility="{Binding Spikes.Count, Converter={StaticResource CountZeroToVis}}" />
        </Grid>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
