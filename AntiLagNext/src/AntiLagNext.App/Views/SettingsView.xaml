<UserControl x:Class="AntiLagNext.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16">
      <StackPanel>
        <TextBlock Text="Тема" FontWeight="Bold" Margin="0,0,0,8" />
        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" Width="200" HorizontalAlignment="Left" />

        <Separator Margin="0,16" />

        <DockPanel Margin="0,6">
          <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        IsChecked="{Binding CreateRestorePoint}" />
          <StackPanel>
            <TextBlock Text="Точка восстановления перед изменениями" FontWeight="SemiBold" />
            <TextBlock Text="System Restore + JSON-бэкап ключей. Рекомендуется." FontSize="11" Foreground="{StaticResource MutedText}" />
          </StackPanel>
        </DockPanel>

        <DockPanel Margin="0,6">
          <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        IsChecked="{Binding MonitoringEnabled}" />
          <TextBlock Text="Мониторинг при запуске" VerticalAlignment="Center" FontWeight="SemiBold" />
        </DockPanel>

        <DockPanel Margin="0,8">
          <TextBlock Text="Интервал мониторинга, мс:" VerticalAlignment="Center" Width="220" />
          <TextBox Text="{Binding MonitoringIntervalMs}" Width="80" />
        </DockPanel>

        <DockPanel Margin="0,6">
          <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        IsChecked="{Binding GameAutoSwitchEnabled}" />
          <StackPanel>
            <TextBlock Text="Авто-профиль при запуске игр" FontWeight="SemiBold" />
            <TextBlock Text="WMI ProcessStartTrace по списку exe в профилях" FontSize="11" Foreground="{StaticResource MutedText}" />
          </StackPanel>
        </DockPanel>

        <Separator Margin="0,16" />

        <DockPanel Margin="0,6">
          <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        IsChecked="{Binding MinimizeToTray}" />
          <StackPanel>
            <TextBlock Text="Сворачивать в трей" FontWeight="SemiBold" />
            <TextBlock Text="Закрытие окна не завершает процесс — timer resolution держится (Win11 22H2+)."
                       FontSize="11" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
          </StackPanel>
        </DockPanel>

        <DockPanel Margin="0,6">
          <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}"
                        IsChecked="{Binding ReleaseTimerOnExit}" />
          <StackPanel>
            <TextBlock Text="Отпускать таймер при полном выходе" FontWeight="SemiBold" />
            <TextBlock Text="Через «Выход» в меню трея. Иначе resolution сбросится только после kill процесса."
                       FontSize="11" Foreground="{StaticResource MutedText}" TextWrapping="Wrap" />
          </StackPanel>
        </DockPanel>

        <DockPanel Margin="0,8">
          <TextBlock Text="Макс. число бэкапов:" VerticalAlignment="Center" Width="220" />
          <TextBox Text="{Binding MaxBackupsToKeep}" Width="80" />
        </DockPanel>

        <Button Content="Сохранить настройки" Margin="0,20,0,0" HorizontalAlignment="Left"
                Style="{StaticResource MaterialDesignRaisedButton}"
                Command="{Binding SaveCommand}" />
        <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" />
      </StackPanel>
    </Border>
  </ScrollViewer>
</UserControl>
