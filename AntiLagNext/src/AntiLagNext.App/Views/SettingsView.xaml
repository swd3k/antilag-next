<UserControl x:Class="AntiLagNext.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
  <StackPanel MaxWidth="720" HorizontalAlignment="Left">
    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
      <StackPanel>
        <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedText}" Margin="0,0,0,12" />
        <TextBlock Text="Тема" FontSize="12" Foreground="{StaticResource MutedText}" Margin="0,0,0,6" />
        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" Width="220" HorizontalAlignment="Left" />
      </StackPanel>
    </Border>

    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
      <StackPanel>
        <TextBlock Text="SAFETY &amp; MONITORING" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedText}" Margin="0,0,0,12" />
        <Border Style="{StaticResource OptRow}">
          <DockPanel>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding CreateRestorePoint}" />
            <StackPanel>
              <TextBlock Text="Точка восстановления" FontWeight="SemiBold" />
              <TextBlock Text="System Restore + JSON backup" FontSize="11" Foreground="{StaticResource MutedText}" />
            </StackPanel>
          </DockPanel>
        </Border>
        <Border Style="{StaticResource OptRow}">
          <DockPanel>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding MonitoringEnabled}" />
            <TextBlock Text="Мониторинг при запуске" FontWeight="SemiBold" VerticalAlignment="Center" />
          </DockPanel>
        </Border>
        <DockPanel Margin="4,8">
          <TextBlock Text="Интервал, мс" Width="140" VerticalAlignment="Center" Foreground="{StaticResource MutedText}" />
          <TextBox Text="{Binding MonitoringIntervalMs}" Width="100" HorizontalAlignment="Left" />
        </DockPanel>
        <Border Style="{StaticResource OptRow}" Margin="0">
          <DockPanel>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding GameAutoSwitchEnabled}" />
            <StackPanel>
              <TextBlock Text="Авто-профиль при играх" FontWeight="SemiBold" />
              <TextBlock Text="WMI ProcessStartTrace" FontSize="11" Foreground="{StaticResource MutedText}" />
            </StackPanel>
          </DockPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Style="{StaticResource GlassCard}" Margin="0,0,0,16" CornerRadius="20">
      <StackPanel>
        <TextBlock Text="TRAY &amp; TIMER" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedText}" Margin="0,0,0,12" />
        <Border Style="{StaticResource OptRow}">
          <DockPanel>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding MinimizeToTray}" />
            <TextBlock Text="Сворачивать в трей" FontWeight="SemiBold" VerticalAlignment="Center" />
          </DockPanel>
        </Border>
        <Border Style="{StaticResource OptRow}">
          <DockPanel>
            <ToggleButton DockPanel.Dock="Right" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding ReleaseTimerOnExit}" />
            <TextBlock Text="Отпускать таймер при выходе" FontWeight="SemiBold" VerticalAlignment="Center" />
          </DockPanel>
        </Border>
        <DockPanel Margin="4,8,4,0">
          <TextBlock Text="Макс. бэкапов" Width="140" VerticalAlignment="Center" Foreground="{StaticResource MutedText}" />
          <TextBox Text="{Binding MaxBackupsToKeep}" Width="100" HorizontalAlignment="Left" />
        </DockPanel>
      </StackPanel>
    </Border>

    <Button Content="SAVE SETTINGS" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" HorizontalAlignment="Left" />
    <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentBrush}" />
  </StackPanel>
</UserControl>
